# Customer app (Expo) — copy to .env for local development.
# Only public Supabase values belong here. No service-role key. No Clover secrets.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Clover Hosted Checkout is opened via URL from an Edge Function — never a client secret.
CLOVER_ENV=sandbox

TWILIO_ENABLED=false
EMAIL_PROVIDER=resend
