# DChill Outpost — monorepo environment (placeholders only; copy to .env locally).
# Never commit real credentials. Service-role and Clover secrets are server-only (Edge Functions).

# Public Supabase client config (safe for mobile + admin bundles)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Clover (payments) — public identifiers / mode only; secrets live in Edge Function env
CLOVER_ENV=sandbox
CLOVER_MERCHANT_ID=

# Notifications (feature flags / provider selection — not API secrets)
TWILIO_ENABLED=false
EMAIL_PROVIDER=resend
