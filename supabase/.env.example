# Supabase local / Edge Functions — copy to .env for server-side development.
# Real secrets belong in Supabase project secrets or CI — never in client apps or git.

# Project URL (public)
SUPABASE_URL=

# Anon key (public — used by clients)
SUPABASE_ANON_KEY=

# Additional server-only secrets (service role, Clover tokens) belong in Supabase project secrets or CI — not in this file.

# Clover — server-only tokens belong in Edge Function secrets / clover_credentials (RLS-blocked)
CLOVER_ENV=sandbox
CLOVER_MERCHANT_ID=

TWILIO_ENABLED=false
EMAIL_PROVIDER=resend
